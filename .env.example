# Application Branding Configuration
# These values will be displayed on the landing page and throughout the application

# Short application name (displayed in title, branding, etc.)
APP_NAME=ESIMPEG

# Full application name/description (displayed in subtitle)
APP_LONG_NAME=Elektronik Sistem Informasi Manajemen Pegawai

# Institution/Organization name
APP_INSTANSI=Pemerintah Kabupaten Pesisir Selatan

# Application description (can be used in meta tags, about page, etc.)
APP_DESCRIPTION=Platform kepegawaian terintegrasi dengan SIASN

# Example for different instance:
# APP_NAME=SIMPEG-PADANG
# APP_LONG_NAME=Sistem Informasi Manajemen Pegawai Kota Padang
# APP_INSTANSI=Pemerintah Kota Padang
# APP_DESCRIPTION=Platform manajemen kepegawaian Kota Padang
